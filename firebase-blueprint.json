{
  "entities": {
    "profile": {
      "title": "Profile",
      "description": "User's personal information and self-introduction.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the user.",
          "maxLength": 100
        },
        "title": {
          "type": "string",
          "description": "Professional title (e.g. Frontend Developer).",
          "maxLength": 100
        },
        "bio": {
          "type": "string",
          "description": "Self introduction biography.",
          "maxLength": 2000
        },
        "email": {
          "type": "string",
          "description": "Contact email.",
          "maxLength": 100
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number.",
          "maxLength": 20
        },
        "avatar": {
          "type": "string",
          "description": "Base64 data URL or external URL of avatar.",
          "maxLength": 500000
        },
        "skills": {
          "type": "string",
          "description": "Comma separated list of skills.",
          "maxLength": 1000
        },
        "github": {
          "type": "string",
          "description": "GitHub profile link.",
          "maxLength": 200
        },
        "linkedin": {
          "type": "string",
          "description": "LinkedIn profile link.",
          "maxLength": 200
        },
        "website": {
          "type": "string",
          "description": "Personal website link.",
          "maxLength": 200
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO timestamp of last update."
        }
      },
      "required": ["name", "title", "bio", "email"]
    },
    "education": {
      "title": "Education",
      "description": "Education background entry.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "school": {
          "type": "string",
          "description": "School name.",
          "maxLength": 100
        },
        "major": {
          "type": "string",
          "description": "Major of study.",
          "maxLength": 100
        },
        "degree": {
          "type": "string",
          "description": "Degree obtained (e.g. Bachelor, Master).",
          "maxLength": 50
        },
        "startDate": {
          "type": "string",
          "description": "Start date.",
          "maxLength": 20
        },
        "endDate": {
          "type": "string",
          "description": "End date (or 'Present').",
          "maxLength": 20
        },
        "description": {
          "type": "string",
          "description": "Description of activities or achievements.",
          "maxLength": 1000
        },
        "userId": {
          "type": "string",
          "description": "Owner user ID."
        },
        "order": {
          "type": "integer",
          "description": "Sort order index."
        }
      },
      "required": ["school", "major", "degree", "startDate", "endDate", "userId"]
    },
    "experience": {
      "title": "Work Experience",
      "description": "Work experience entry.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "company": {
          "type": "string",
          "description": "Company name.",
          "maxLength": 100
        },
        "role": {
          "type": "string",
          "description": "Role or position.",
          "maxLength": 100
        },
        "startDate": {
          "type": "string",
          "description": "Start date.",
          "maxLength": 20
        },
        "endDate": {
          "type": "string",
          "description": "End date (or 'Present').",
          "maxLength": 20
        },
        "description": {
          "type": "string",
          "description": "Key responsibilities and achievements.",
          "maxLength": 2000
        },
        "userId": {
          "type": "string",
          "description": "Owner user ID."
        },
        "order": {
          "type": "integer",
          "description": "Sort order index."
        },
        "industry": {
          "type": "string",
          "description": "Industry of the company.",
          "maxLength": 100
        },
        "location": {
          "type": "string",
          "description": "Work location.",
          "maxLength": 100
        }
      },
      "required": ["company", "role", "startDate", "endDate", "userId"]
    },
    "projects": {
      "title": "Projects",
      "description": "Portfolio project display.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "title": {
          "type": "string",
          "description": "Project name.",
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "description": "Brief project description.",
          "maxLength": 1000
        },
        "image": {
          "type": "string",
          "description": "Base64 data URL or external URL of project screenshot.",
          "maxLength": 500000
        },
        "link": {
          "type": "string",
          "description": "Project website or GitHub link.",
          "maxLength": 200
        },
        "techStack": {
          "type": "string",
          "description": "Comma separated technologies used.",
          "maxLength": 500
        },
        "userId": {
          "type": "string",
          "description": "Owner user ID."
        },
        "order": {
          "type": "integer",
          "description": "Sort order index."
        },
        "extraImages": {
          "type": "array",
          "description": "Additional screenshots (up to 5 images)."
        },
        "videoUrl": {
          "type": "string",
          "description": "Embedded video or YouTube URL.",
          "maxLength": 500
        }
      },
      "required": ["title", "description", "userId"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "profile",
      "description": "The personal profile document for each user."
    },
    "/educations/{educationId}": {
      "schema": "education",
      "description": "The education history records."
    },
    "/experiences/{experienceId}": {
      "schema": "experience",
      "description": "The work experience history records."
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "The user projects portfolio records."
    }
  }
}
